# =============================================================
# trench_geometry.lsf
# MSc Project — THz CPW Resonator
#
# Builds the trench geometry in Lumerical FDTD:
#   - CPW signal line (split at coupling gap)
#   - Ground planes (surface + buried sidewalls)
#   - Air-filled trench volumes (upper and lower trenches)
#
# Variable definitions (match Lumerical user properties panel):
#   s          = 10   µm  – signal conductor width
#   w          =  7.5 µm  – slot width
#   C_g        =  3   µm  – coupling gap length
#   cav_L      = 80   µm  – cavity length
#   L_burried  =  5   µm  – trench width in y
#   y_height   =  5   µm  – extra ground offset above slot
#   h_burried  = 50   µm  – trench depth in z
#   x_offset   = -200 µm  – cavity centre x position
#   material   = PEC (Perfect Electrical Conductor)
#   air        = etch material
# =============================================================

# -------------------------------------------------------------
# VARIABLE DEFINITIONS
# -------------------------------------------------------------
s          = 10e-6;     # signal conductor width   (m)
w          = 7.5e-6;    # slot width                (m)
C_g        = 3e-6;      # coupling gap length       (m)
cav_L      = 80e-6;     # cavity length             (m)
L_burried  = 5e-6;      # trench width in y         (m)
y_height   = 5e-6;      # ground offset above slot  (m)
h_burried  = 50e-6;     # trench depth in z         (m)
x_offset   = -200e-6;   # cavity centre x position     (m)
material   = "PEC (Perfect Electrical Conductor)";
air        = "etch";

deleteall;


# -------------------------------------------------------------
# SIGNAL LINE  (3 segments: left feed | cavity | right feed)
# -------------------------------------------------------------
# We centre the cavity at x = x_offset.
# The cavity spans from x = x_offset - cav_L/2 to x_offset + cav_L/2.

# Left feed
add2drect;
set("name","signal");
set("y min", -s/2);
set("y max",  s/2);
set("x min", -2000e-6);
set("x max", x_offset - cav_L/2 - C_g);
set("z", 0e-6);
set("material", material);

# Cavity segment
add2drect;
set("name","signal2");
set("y min", -s/2);
set("y max",  s/2);
set("x min", x_offset - cav_L/2);
set("x max", x_offset + cav_L/2);
set("z", 0);
set("material", material);

# Right feed
add2drect;
set("name","signal3");
set("y min", -s/2);
set("y max",  s/2);
set("x min", x_offset + cav_L/2 + C_g);
set("x max",  2000e-6);
set("z", 0);
set("material", material);

# -------------------------------------------------------------
# GROUND PLANES — surface layer (4 rectangles)
# -------------------------------------------------------------

# Lower ground — deep buried section
add2drect;
set("name","GND_down");
set("y min", -1000e-6);
set("y max", -(s/2 + w + y_height + L_burried));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", 0e-6);
set("material", material);

# Lower ground — trench inner face
add2drect;
set("name","GND_down_inner");
set("y min", -(s/2 + w + y_height));
set("y max", -(s/2 + w));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", 0e-6);
set("material", material);

# Upper ground — deep buried section
add2drect;
set("name","GND_up");
set("y max",  1000e-6);
set("y min",  (s/2 + w + y_height + L_burried));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", 0e-6);
set("material", material);

# Upper ground — trench inner face
add2drect;
set("name","GND_up_inner");
set("y max",  (s/2 + w + y_height));
set("y min",  (s/2 + w));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", 0e-6);
set("material", material);

# -------------------------------------------------------------
# TRENCH SIDEWALLS — bottom faces (z-normal, buried in z)
# -------------------------------------------------------------

# Upper trench — bottom face (inner wall)
add2drect;
set("name","trench_upper_bot_inner");
set("surface normal", 2);   # y-normal
set("y",  (s/2 + w + y_height));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried/2);
set("z span", h_burried);
set("material", material);

# Upper trench — bottom face (outer wall)
add2drect;
set("name","trench_upper_bot_outer");
set("surface normal", 2);   # y-normal
set("y",  (s/2 + w + y_height + L_burried));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried/2);
set("z span", h_burried);
set("material", material);

# Lower trench — bottom face (inner wall)
add2drect;
set("name","trench_lower_bot_inner");
set("surface normal", 2);   # y-normal
set("y", -(s/2 + w + y_height));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried/2);
set("z span", h_burried);
set("material", material);

# Lower trench — bottom face (outer wall)
add2drect;
set("name","trench_lower_bot_outer");
set("surface normal", 2);   # y-normal
set("y", -(s/2 + w + y_height + L_burried));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried/2);
set("z span", h_burried);
set("material", material);

# -------------------------------------------------------------
# TRENCH HORIZONTAL FLOORS — metal at bottom of trench
# -------------------------------------------------------------

# Upper trench floor
add2drect;
set("name","trench_upper_floor");
set("y min",  (s/2 + w + y_height));
set("y max",  (s/2 + w + y_height + L_burried));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried);
set("material", material);

# Lower trench floor
add2drect;
set("name","trench_lower_floor");
set("y min", -(s/2 + w + y_height + L_burried));
set("y max", -(s/2 + w + y_height));
set("x min", -2000e-6);
set("x max",  2000e-6);
set("z", -h_burried);
set("material", material);

# -------------------------------------------------------------
# AIR-FILLED TRENCH VOLUMES
# -------------------------------------------------------------

# Upper air trench
addrect;
set("name","air1");
set("x min", -2000e-6);
set("x max",  2000e-6);
set("y min",  (s/2 + w + y_height));
set("y max",  (s/2 + w + y_height + L_burried));
set("z min", -h_burried);
set("z max",  0e-6);
set("material", air);

# Lower air trench
addrect;
set("name","air2");
set("x min", -2000e-6);
set("x max",  2000e-6);
set("y min", -(s/2 + w + y_height + L_burried));
set("y max", -(s/2 + w + y_height));
set("z min", -h_burried);
set("z max",  0e-6);
set("material", air);
